{
  "info": {
    "name": "UESAN Shopping API",
    "description": "Colección de endpoints para la API de UESAN Shopping.\n\n## Autenticación\n1. Ejecuta **Signin** en la carpeta User para obtener un token JWT.\n2. El token se guarda automáticamente en la variable `authToken`.\n3. Las carpetas Category y Product heredan la autenticación Bearer automáticamente.\n\n## Variables de colección\n- `baseUrl`: URL base del API (por defecto `http://localhost:5170`)\n- `authToken`: Token JWT (se actualiza automáticamente al hacer signin)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "User",
      "description": "Endpoints públicos de autenticación y registro de usuarios.",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "description": "Registra un nuevo usuario en el sistema.",
            "url": {
              "raw": "{{baseUrl}}/api/user",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Juan\",\n  \"lastName\": \"Perez\",\n  \"email\": \"juan.perez@email.com\",\n  \"password\": \"123456\",\n  \"dateOfBirth\": \"1995-06-15\",\n  \"country\": \"Peru\",\n  \"address\": \"Av. Principal 123\",\n  \"type\": \"C\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Signin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "description": "Inicia sesión y obtiene un token JWT.\n\nEl token se guarda automáticamente en la variable `authToken` de la colección.",
            "url": {
              "raw": "{{baseUrl}}/api/user/signin",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "signin"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan.perez@email.com\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('authToken', jsonData.token);",
                  "    console.log('Token guardado correctamente:', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Category",
      "description": "CRUD de categorías. Requiere autenticación JWT.",
      "item": [
        {
          "name": "Get All",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Obtiene todas las categorías activas.",
            "url": {
              "raw": "{{baseUrl}}/api/category",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "category"]
            }
          }
        },
        {
          "name": "Get By Id",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Obtiene una categoría por su ID.",
            "url": {
              "raw": "{{baseUrl}}/api/category/{{categoryId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "category", "{{categoryId}}"],
              "variable": [
                {
                  "key": "categoryId",
                  "value": "1",
                  "description": "ID de la categoría"
                }
              ]
            }
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Crea una nueva categoría.\n\nEl campo `isActive` no se incluye en CategoryCreateDTO pero puede enviarse opcionalmente.",
            "url": {
              "raw": "{{baseUrl}}/api/category",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "category"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Nueva categoría\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Actualiza una categoría existente. El ID en la URL debe coincidir con el ID del body.",
            "url": {
              "raw": "{{baseUrl}}/api/category/{{categoryId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "category", "{{categoryId}}"],
              "variable": [
                {
                  "key": "categoryId",
                  "value": "1",
                  "description": "ID de la categoría a actualizar"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"description\": \"Descripción actualizada\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "header": [],
            "description": "Elimina una categoría por su ID.",
            "url": {
              "raw": "{{baseUrl}}/api/category/{{categoryId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "category", "{{categoryId}}"],
              "variable": [
                {
                  "key": "categoryId",
                  "value": "1",
                  "description": "ID de la categoría a eliminar"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Product",
      "description": "CRUD de productos. Requiere autenticación JWT.",
      "item": [
        {
          "name": "Get All",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Obtiene todos los productos activos.",
            "url": {
              "raw": "{{baseUrl}}/api/product",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "product"]
            }
          }
        },
        {
          "name": "Get By Id",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Obtiene un producto por su ID.",
            "url": {
              "raw": "{{baseUrl}}/api/product/{{productId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "product", "{{productId}}"],
              "variable": [
                {
                  "key": "productId",
                  "value": "1",
                  "description": "ID del producto"
                }
              ]
            }
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Crea un nuevo producto.\n\nEl campo `isActive` no se incluye en ProductCreateDTO pero puede enviarse opcionalmente.",
            "url": {
              "raw": "{{baseUrl}}/api/product",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "product"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Producto de ejemplo\",\n  \"imageUrl\": \"https://ejemplo.com/imagen.jpg\",\n  \"stock\": 10,\n  \"price\": 49.90,\n  \"discount\": 5,\n  \"categoryId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Actualiza un producto existente. El ID en la URL debe coincidir con el ID del body.",
            "url": {
              "raw": "{{baseUrl}}/api/product/{{productId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "product", "{{productId}}"],
              "variable": [
                {
                  "key": "productId",
                  "value": "1",
                  "description": "ID del producto a actualizar"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"description\": \"Producto actualizado\",\n  \"imageUrl\": \"https://ejemplo.com/imagen.jpg\",\n  \"stock\": 15,\n  \"price\": 59.90,\n  \"discount\": 0,\n  \"categoryId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "header": [],
            "description": "Elimina un producto por su ID.",
            "url": {
              "raw": "{{baseUrl}}/api/product/{{productId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "product", "{{productId}}"],
              "variable": [
                {
                  "key": "productId",
                  "value": "1",
                  "description": "ID del producto a eliminar"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5170",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    }
  ]
}
